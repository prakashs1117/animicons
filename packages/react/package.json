{
  "name": "@animicons/react",
  "version": "0.1.3",
  "description": "Animated SVG icon library for React",
  "license": "MIT",
  "homepage": "https://github.com/prakashs1117/animicons#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/prakashs1117/animicons.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/prakashs1117/animicons/issues"
  },
  "keywords": [
    "animated",
    "icons",
    "svg",
    "react",
    "animation",
    "ui",
    "healthcare"
  ],
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native-svg": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {}
}
